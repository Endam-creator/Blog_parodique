<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Blog des Vérités Cachées - La voix de ceux qui savent</title>
    <style>
        :root {
            --bg-color: #1a1a1a;
            --card-bg: #2d2d2d;
            --text-color: #ffffff;
            --accent-green: #76b900;
            --accent-green-hover: #8ae000;
            --border-color: #444444;
            --danger-red: #8b0000;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Courier New', Courier, monospace;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
            background-image: radial-gradient(rgba(0, 150, 0, 0.05) 15%, transparent 16%);
            background-size: 15px 15px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            border: 3px solid var(--border-color);
            background-color: #151515;
            box-shadow: 0 0 20px rgba(0,0,0,0.8);
        }

        /* HEADER */
        header {
            display: flex;
            align-items: center;
            background-color: #222;
            padding: 15px 20px;
            border-bottom: 4px solid var(--accent-green);
            position: relative;
        }

        .logo-area {
            position: relative;
            margin-right: 20px;
        }

        .logo-circle {
            width: 80px;
            height: 80px;
            background-color: var(--accent-green);
            border-radius: 50%;
            border: 3px solid var(--text-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 45px;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }

        .loupe-handle {
            position: absolute;
            width: 35px;
            height: 8px;
            background: linear-gradient(#fff, #666);
            bottom: -5px;
            left: -15px;
            transform: rotate(45deg);
            border-radius: 2px;
        }

        .header-titles h1 {
            font-size: 2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .header-titles p {
            color: var(--accent-green);
            font-style: italic;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .edition-tag {
            font-size: 0.9rem;
            color: #aaa;
            margin-top: 2px;
        }

        /* MAIN CONTENT GRID */
        .main-layout {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            padding: 20px;
        }

        @media (min-width: 900px) {
            .main-layout {
                grid-template-columns: 65fr 35fr;
            }
        }

        /* LEFT COLUMN (FEATURED) */
        .featured-story {
            border: 2px solid var(--border-color);
            background-color: #1e1e1e;
            position: relative;
        }

        .breaking-tag {
            background-color: var(--accent-green);
            color: #000;
            padding: 5px 15px;
            font-weight: bold;
            display: inline-block;
            text-transform: uppercase;
            font-size: 0.9rem;
            margin: 10px;
        }

        .story-hero-img {
            width: 100%;
            height: 300px;
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.7)), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23333"/><text x="50" y="55" font-family="monospace" font-size="6" fill="%23555" text-anchor="middle">Z0NE_DE_GUERRE_PSYCHIQUE.RAW</text></svg>');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
            padding: 20px;
            border-bottom: 2px solid var(--border-color);
        }

        .story-hero-img h2 {
            font-size: 1.5rem;
            text-shadow: 2px 2px 4px #000;
            line-height: 1.3;
        }

        .story-hero-img h2 a {
            color: var(--text-color);
            text-decoration: none;
        }

        .story-hero-img h2 a:hover {
            color: var(--accent-green);
        }

        .manifesto-text {
            padding: 20px;
            line-height: 1.6;
            font-size: 0.95rem;
            border-bottom: 2px solid var(--border-color);
        }

        .manifesto-text strong {
            color: var(--accent-green);
        }

        /* RIGHT COLUMN (FEED) */
        .stories-feed {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .feed-card {
            display: grid;
            grid-template-columns: 100px 1fr;
            border: 1px solid var(--border-color);
            background-color: #1a1a1a;
            min-height: 90px;
            position: relative;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            transition: border-color 0.2s;
        }

        .feed-card:hover {
            border-color: var(--accent-green);
        }

        .feed-img {
            background-color: #252525;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            border-right: 1px solid var(--border-color);
        }

        .feed-content {
            padding: 10px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .feed-title {
            font-size: 0.85rem;
            font-weight: bold;
            color: var(--accent-green);
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .feed-desc {
            font-size: 0.8rem;
            color: #ccc;
            line-height: 1.3;
        }

        .classified-stamp {
            position: absolute;
            bottom: 2px;
            right: 5px;
            border: 1px solid var(--danger-red);
            color: var(--danger-red);
            font-size: 0.6rem;
            padding: 1px 4px;
            font-weight: bold;
            transform: rotate(-5deg);
            text-transform: uppercase;
            opacity: 0.7;
        }

        /* NEWSLETTER BAR */
        .newsletter-bar {
            background-color: #222;
            border-top: 2px solid var(--border-color);
            padding: 15px 20px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 15px;
        }

        .subscribe-tag {
            color: var(--accent-green);
            font-weight: bold;
            font-size: 1.3rem;
            text-transform: uppercase;
        }

        .newsletter-form {
            display: flex;
            flex-grow: 1;
            max-width: 500px;
            gap: 10px;
        }

        .newsletter-form input {
            flex-grow: 1;
            background-color: #000;
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 8px 12px;
            font-family: inherit;
        }

        .newsletter-form input:focus {
            outline: 1px solid var(--accent-green);
        }

        .btn-submit {
            background-color: var(--accent-green);
            color: #000;
            border: none;
            padding: 8px 20px;
            font-weight: bold;
            cursor: pointer;
            font-family: inherit;
        }

        .btn-submit:hover {
            background-color: var(--accent-green-hover);
        }

        .sub-caption {
            font-size: 0.75rem;
            color: #aaa;
            width: 100%;
            margin-top: 5px;
        }

        .social-icons {
            display: flex;
            gap: 15px;
            font-size: 1.2rem;
            color: #888;
        }

        /* FOOTER NAVIGATION */
        footer {
            background-color: #111;
            border-top: 4px solid var(--border-color);
            padding: 15px;
            text-align: center;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 25px;
            margin-bottom: 5px;
        }

        .footer-links a {
            color: #bbb;
            text-decoration: underline;
            font-size: 0.85rem;
        }

        .footer-links a:hover {
            color: var(--accent-green);
        }
    </style>
</head>
<body>

